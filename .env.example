TM4_BASE_PATH=/var/lib/tm4
TM4_POLL_INTERVAL_S=3

# TM4 Core Integration
TM4_CORE_PATH=/opt/tm4-core
TM4_AUTONOMY_SCRIPT=/opt/tm4-core/mvp/scripts/run_autonomy_loop.py
TM4_PYTHON_BIN=python

# Reporting Configuration
# TM4_DOCS_ROOT=/opt/tm4server/docs/experiments

# Optional: Set to 1 to enable automated pushing of reports to GitHub (requires Git auth setup)
# Auto-push requires TM4_DOCS_ROOT to resolve inside the TM4Server Git repository.
TM4_AUTO_PUSH_REPORTS=0
